{
  "$schema": "http://json-schema.org/draft-07/schema",
  "required": [
    "pce_url",
    "cluster_id",
    "cluster_token",
    "cluster_code",
    "containerRuntime",
    "containerManager",
    "imagePullSecret"
  ],
  "properties": {
    "pce_url": {
      "type": "string"
    },
    "cluster_id": {
      "type": "string"
    },
    "cluster_token": {
      "type": "string"
    },
    "cluster_code": {
      "type": "string"
    },
    "containerRuntime": {
      "type": "string",
      "enum": ["containerd", "docker", "crio", "k3s_containerd"]
    },
    "containerManager": {
      "type": "string",
      "enum": ["kubernetes", "openshift"]
    },
    "ignore_cert": {
      "type": "boolean"
    },
    "verbosity": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "networkType": {
      "type": "string",
      "enum": ["flat", "overlay"]
    },
    "imagePullSecret": {
      "type": "object",
      "required": [
        "username",
        "password"
      ],
      "properties": {
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        }
      }
    },
    "clusterMode": {
      "type": "string",
      "enum": ["legacy", "migrateLegacyToClas", "clas", "migrateClasToLegacy", "unpair"]
    },
    "waitForPolicy": {
      "type": "object",
      "required": [
        "enabled",
        "ignoredNamespaces"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "ignoredNamespaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "priorityClasses": {
      "type": "object",
      "required": [
        "enabled",
        "kubelink",
        "cven"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "kubelink": {
          "type": "string"
        },
        "cven": {
          "type": "string"
        }
      }
    },
    "degradedModePolicyFail": {
      "type": "string",
      "enum": ["open", "closed"]
    },
    "disableDegradedMode": {
      "type": "boolean"
    },
    "policyLabelSetEnable": {
      "type": "boolean"
    },
    "reportHostNetworkKubernetesWorkloads": {
      "type": "boolean"
    },
    "enforceNodePortTraffic": {
      "type": "string",
      "enum": ["always", "never"]
    },
    "kubelink": {
      "type": "object",
      "required": [
        "registry",
        "repo",
        "imageTag",
        "imagePullPolicy"
      ],
      "properties": {
        "registry": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "imageTag": {
          "type": "string"
        },
        "imagePullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "pceApiTimeout": {
          "type": "integer",
          "minimum": 60,
          "maximum": 7200
        },
        "pceApiMinBackoff": {
          "type": "integer",
          "minimum": 5,
          "maximum": 600
        },
        "pceApiMaxBackoff": {
          "type": "integer",
          "minimum": 60,
          "maximum": 1200
        },
        "pceApiPolicyInterval": {
          "type": "integer",
          "minimum": 10,
          "maximum": 3600
        },
        "lastAppliedPolicyUpdateInterval": {
          "type": "integer",
          "minimum": 5
        },
        "etcdRetryAttempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "resources": {
          "type": "object"
        }
      }
    },
    "cven": {
      "type": "object",
      "required": [
        "registry",
        "repo",
        "imageTag",
        "imagePullPolicy",
        "hostBasePath"
      ],
      "properties": {
        "registry": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "imageTag": {
          "type": "string"
        },
        "imagePullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "hostBasePath": {
          "type": "string"
        },
        "firewallBackend": {
          "type": "string",
          "enum": ["auto", "iptables", "nftables"]
        },
        "resources": {
          "type": "object"
        },
        "aggressiveTamperingDetection": {
          "type": "boolean"
        },
        "tolerations": {
          "type": ["array"],
          "description": "Tolerations for C-VEN Daemonset",
          "default": [],
          "items": {}
        }
      }
    },
    "initcontainer": {
      "type": "object",
      "required": [
        "registry",
        "repo",
        "imageTag",
        "imagePullPolicy"
      ],
      "properties": {
        "registry": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "imageTag": {
          "type": "string"
        },
        "imagePullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "storage": {
      "type": "object",
      "required": [
        "registry",
        "repo",
        "imageTag",
        "imagePullPolicy",
        "sizeGi"
      ],
      "properties": {
        "registry": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "imageTag": {
          "type": "string"
        },
        "imagePullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "sizeGi": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "resources": {
          "type": "object"
        },
        "additionalEnv": {
          "type": "array",
          "description": "Additional environment variables for the etcd storage pod",
          "default": [
            {
              "name": "ETCD_EXPERIMENTAL_SNAPSHOT_CATCHUP_ENTRIES",
              "value": "1"
            },
            {
              "name": "ETCD_SNAPSHOT_CATCHUP_ENTRIES",
              "value": "1"
            }
          ],
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string"
              },
              "value": {
                "type": "string"
              },
              "valueFrom": {
                "type": "object"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "useTLS": {
      "type": "boolean"
    }
  }
}
